.window {
  top: 50%;
  left: 50%;
  width: 300;
  height: 180;
  alignment-x: center;
  alignment-y: center;

  .header {
    left: 50%;
    width: 100%;
    height: 20;
    padding: 0 2 0 2;
    space-between-entries: 3;

    .head {
      width: 16;
      height: width;
      alignment: center;
    }

    .username {
      alignment: center;
    }
  }

  .content {
    width: 100%;
    height: 160;
    alignment-x: center;
    alignment-y: center;
    overwrite-width: false;

    Dropdown {
      width: 112;
      margin-top: 20;
      alignment-x: center;
    }

    TextField {
      width: 100;
      margin-top: 10;
      alignment-x: center;
    }

    Button {
      margin-top: 10;
      alignment-x: center;
    }
  }
}