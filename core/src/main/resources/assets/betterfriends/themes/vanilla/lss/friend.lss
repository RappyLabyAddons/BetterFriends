Friend, FriendlistFriend {
  width: 100%;
  height: 20;
  padding: 1;

  .player-head {
    margin-left: 3;
    width: 16;
    height: width;
  }

  .indicator {
    width: 8;
    height: width;
  }

  .username {
    max-width: 80%;
    width: fit-content;
    scale-to-fit: true;
    max-lines: 1;
    margin-left: 2;
    top: 2;
  }

  .pin-icon {
    margin-left: 3;
    width: 8;
    height: width;
  }

  .buttons {
    height: fit-content;
    width: fit-content;
    alignment: right;

    Button {
      width: 20;
      height: width;
      padding: 0;
    }

    .pin-button {
      .button-icon {
        width: 50%;
        height: width;
      }
    }
  }
}