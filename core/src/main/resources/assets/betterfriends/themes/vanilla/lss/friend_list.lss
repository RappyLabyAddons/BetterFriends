.container {
   height: 100%;
   width: 100%;

   Scroll {
     width: 100%;
     height: 100%;

     .friends {
       margin-top: 5;
       width: 100%;
       height: fit-content;
     }

     Scrollbar {
       left: 0;
       top: 0;
       width: 5;
       height: 100%;
       margin-left: 5;
     }
   }

   .error {
     font-size: 0.8;
     text-color: red;
     width: fit-content;
     margin-top: 100;
     alignment-x: center;
     alignment-y: center;
   }
 }